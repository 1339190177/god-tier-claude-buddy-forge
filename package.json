{
  "name": "claude-buddy-universe-cracker",
  "version": "1.0.0",
  "description": "Claude Code /buddy 宠物刷取工具 - 帮你在 /buddy 中刷到想要的传奇宠物",
  "type": "commonjs",
  "main": "lib/rng.js",
  "scripts": {
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css,html}\"",
    "type-check": "tsc --noEmit",
    "test": "npm run lint && npm run format:check",
    "prepare": "husky || true"
